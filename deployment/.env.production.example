# =============================================================================
# ExpenseFlow — Production Environment Template
# Copy to: /var/www/expenseflow/shared/.env
# chmod 640 /var/www/expenseflow/shared/.env
# chown deployer:www-data /var/www/expenseflow/shared/.env
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="ExpenseFlow"
APP_ENV=production
APP_KEY=                          # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://expenseflow.example.com
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=expenseflow_prod
DB_USERNAME=expenseflow
DB_PASSWORD=                      # from /root/expenseflow-credentials.txt
DB_SCHEMA=public
DB_SSLMODE=prefer

# ── Cache & Sessions ──────────────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ── Mail (Brevo SMTP) ─────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=                    # Brevo SMTP login (your account email)
MAIL_PASSWORD=                    # Brevo SMTP key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@expenseflow.example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage ───────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAYS=14

# ── OCR ───────────────────────────────────────────────────────────────────────
OCR_ENABLED=true
OCR_PYTHON_BIN=/opt/expenseflow-ocr/bin/python3
OCR_TESSERACT_BIN=/usr/bin/tesseract
OCR_LANGUAGE=tam+eng
OCR_TIMEOUT=60
OCR_SCRIPT_PATH=/var/www/expenseflow/shared/storage/app/ocr/invoice_ocr.py
OCR_TEMP_DIR=/var/www/expenseflow/shared/storage/app/public/temp-qr

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Asset mode ────────────────────────────────────────────────────────────────
ASSET_MODE=auto

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=expenseflow.example.com

# ── Telescope (disable in production unless needed) ───────────────────────────
TELESCOPE_ENABLED=false

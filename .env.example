APP_NAME=ExpenseFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_LEVEL=warning

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite)
DB_CONNECTION=sqlite

# Production: PostgreSQL (matches deployment/bootstrap.sh)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=expenseflow_prod
# DB_USERNAME=expenseflow
# DB_PASSWORD=

# ── Session ───────────────────────────────────────────────────────────────────
# Local: database | Production: redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Queue ─────────────────────────────────────────────────────────────────────
# Local: database | Production: redis
QUEUE_CONNECTION=database

# ── Cache ─────────────────────────────────────────────────────────────────────
# Local: database | Production: redis
CACHE_STORE=database
# CACHE_PREFIX=expenseflow_

# ── Broadcasting ──────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ── Filesystem ────────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Redis ─────────────────────────────────────────────────────────────────────
# Required in production for cache, sessions, and queues
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1

# ── Mail ──────────────────────────────────────────────────────────────────────
# Local: log
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@expenseflow.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production: Brevo SMTP
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your-brevo-login@example.com
# MAIL_PASSWORD=your-brevo-smtp-key
# MAIL_FROM_ADDRESS="noreply@yourdomain.com"
# MAIL_FROM_NAME="${APP_NAME}"

# ── AWS / S3 (optional) ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
